{
  "layout": {
    "type": "Column",
    "fillMaxSize": true,
    "classes": ["screen"],
    "children": [
      {
        "type": "Row",
        "fillMaxWidth": true,
        "classes": ["header_bar"],
        "children": [
          { "type": "Button", "text": "<< Menu", "action": "launch:menu" },
          { "type": "Text", "text": "View 2 (Details)", "weight": 1, "classes": ["header_text"] }
        ]
      },
      {
        "type": "Column",
        "weight": 1,
        "fillMaxWidth": true,
        "children": [
          { "type": "Text", "text": "This is the secondary layout view.", "classes": ["section_title"] },
          { "type": "Image", "url": "https://ui-avatars.com/api/?name=View+2&background=random&size=200", "fillMaxWidth": true },
          { "type": "Text", "text": "Notice how the state stays separate, but we are inside the same feature instance.", "classes": ["section_title"] }
        ]
      },
      {
        "type": "Button",
        "text": "<- Back to View 1",
        "action": "switchToView1",
        "fillMaxWidth": true
      }
    ]
  }
}
