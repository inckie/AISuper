{
  "layout": {
    "type": "Column",
    "fillMaxSize": true,
    "classes": ["screen"],
    "children": [
      {
        "type": "Row",
        "fillMaxWidth": true,
        "children": [
          { "type": "Button", "text": "<< Back", "action": "launch:menu" },
          { "type": "Text", "text": "Layout Demo", "weight": 1, "classes": ["header_text"] }
        ]
      },
      {
        "type": "Column",
        "weight": 1,
        "fillMaxWidth": true,
        "isScrollable": true,
        "children": [
          { "type": "Text", "text": "Row with Weights", "classes": ["section_title"] },
          {
            "type": "Row",
            "fillMaxWidth": true,
            "children": [
              { "type": "Button", "text": "Weight 1", "weight": 1, "action": "dummy" },
              { "type": "Button", "text": "Weight 2", "weight": 2, "action": "dummy" },
              { "type": "Button", "text": "Weight 1", "weight": 1, "action": "dummy" }
            ]
          },
          { "type": "Text", "text": "Scrollable Row", "classes": ["section_title"] },
          {
            "type": "Row",
            "fillMaxWidth": true,
            "isScrollable": true,
            "children": [
              { "type": "Button", "text": "Item 1", "action": "dummy" },
              { "type": "Button", "text": "Item 2", "action": "dummy" },
              { "type": "Button", "text": "Item 3", "action": "dummy" },
              { "type": "Button", "text": "Item 4", "action": "dummy" },
              { "type": "Button", "text": "Item 5", "action": "dummy" },
              { "type": "Button", "text": "Item 6", "action": "dummy" }
            ]
          },
          { "type": "Text", "text": "Dynamic Row List", "classes": ["section_title"] },
          {
            "type": "Row",
            "fillMaxWidth": true,
            "isScrollable": true,
            "dynamicChildrenId": "dynamic_row_items"
          },
          { "type": "Text", "text": "Dynamic Column List", "classes": ["section_title"] },
          {
            "type": "Column",
            "fillMaxWidth": true,
            "dynamicChildrenId": "dynamic_col_items"
          }
        ]
      }
    ]
  }
}
