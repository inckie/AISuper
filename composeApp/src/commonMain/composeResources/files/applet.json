{
  "id": "com.damn.aisuper.demo",
  "name": "Super Demo",
  "entryFeature": "menu",
  "styles": {
    "light": {
      "name": "Light",
      "file": "files/styles/light_style.json"
    },
    "dark": {
      "name": "Dark",
      "file": "files/styles/dark_style.json"
    },
    "pink": {
      "name": "Pink",
      "file": "files/styles/pink_style.json"
    },
    "blueOrange": {
      "name": "Blue / Orange",
      "file": "files/styles/blue_orange_style.json"
    },
    "neon": {
      "name": "Neon",
      "file": "files/styles/neon_style.json"
    }
  },
  "defaultStyle": "light",
  "jsModules": {
    "onlineRadioBrowser": {
      "name": "Online Radio Browser",
      "script": "files/online_radio_browser_module.js"
    },
    "miamiMetromover": {
      "name": "Miami Metromover",
      "script": "files/miami_metromover_module.js"
    }
  },
  "features": {
    "menu": {
      "layout": "files/menu_layout.json",
      "script": "files/menu_script.js",
      "name": "Main Menu"
    },
    "chat": {
      "layout": "files/chat_layout.json",
      "script": "files/chat_script.js",
      "name": "Echo Chat"
    },
    "images": {
      "layout": "files/images_layout.json",
      "script": "files/images_script.js",
      "name": "Girl Images",
      "modules": [
        {
          "type": "http",
          "name": "httpMain"
        }
      ]
    },
    "radio": {
      "layout": "files/radio_layout.json",
      "script": "files/radio_script.js",
      "name": "Radio Search",
      "modules": [
        {
          "type": "jsModule",
          "name": "onlineRadioBrowser"
        },
        {
          "type": "http",
          "name": "httpMain"
        },
        {
          "type": "audioPlayer",
          "name": "radioMain"
        }
      ]
    },
    "weather": {
      "layout": "files/weather_layout.json",
      "script": "files/weather_script.js",
      "name": "Weather (MCP)",
      "modules": [
        {
          "type": "mcpHttp",
          "name": "mcp-host-http",
          "config": {
            "url": "http://127.0.0.1:8000/mcp",
            "groups": "weather,miami_metromover"
          }
        },
        {
          "type": "geolocation",
          "name": "geoMain"
        }
      ]
    },
    "metromover": {
      "layout": "files/metromover_layout.json",
      "script": "files/metromover_script.js",
      "name": "Miami Metromover",
      "modules": [
        {
          "type": "mcpHttp",
          "name": "mcp-host-http",
          "config": {
            "url": "http://127.0.0.1:8000/mcp",
            "groups": "miami_metromover"
          }
        },
        {
          "type": "geolocation",
          "name": "geoMain"
        }
      ]
    },
    "metromoverJs": {
      "layout": "files/metromover_layout.json",
      "script": "files/metromover_js_script.js",
      "name": "Miami Metromover (JS Module)",
      "modules": [
        {
          "type": "jsModule",
          "name": "miamiMetromover"
        },
        {
          "type": "http",
          "name": "httpMain"
        },
        {
          "type": "geolocation",
          "name": "geoMain"
        }
      ]
    },
    "form": {
      "layout": "files/form_layout.json",
      "script": "files/form_script.js",
      "name": "Form Demo"
    }
  }
}
