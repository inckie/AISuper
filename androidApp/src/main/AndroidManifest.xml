<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.damn.aisuper.androidapp">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:label="AISuper"
        android:networkSecurityConfig="@xml/network_security_config">
        <activity
            android:name="com.damn.aisuper.MainActivity"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:theme="@android:style/Theme.DeviceDefault.NoActionBar"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Widget configuration activity -->
        <activity
            android:name="com.damn.aisuper.widget.WidgetConfigurationActivity"
            android:exported="true"
            android:theme="@android:style/Theme.DeviceDefault.NoActionBar">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!-- Serves locally cached widget images via content:// URI to RemoteViews -->
        <provider
            android:name="com.damn.aisuper.widget.WidgetImageContentProvider"
            android:authorities="${applicationId}.widget_images"
            android:exported="true"
            android:grantUriPermissions="true" />

        <!-- Single widget receiver for all AISuper feature widgets -->
        <receiver
            android:name="com.damn.aisuper.widget.AISuperWidgetReceiver"
            android:exported="true"
            android:label="AISuper Widget">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/aisuper_widget_info" />
        </receiver>
    </application>

</manifest>
