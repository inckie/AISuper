{
  "layout": {
    "type": "Column",
    "fillMaxSize": true,
    "children": [
      {
        "type": "Button",
        "text": "<< Back",
        "action": "launch:menu"
      },
      {
        "type": "Text",
        "text": "Transmission Torrents",
        "classes": ["section_title"]
      },
      {
        "type": "TextField",
        "id": "host_input",
        "hint": "http://192.168.1.100:9091",
        "singleLine": true,
        "fillMaxWidth": true
      },
      {
        "type": "TextField",
        "id": "login_input",
        "hint": "Username (optional)",
        "singleLine": true,
        "fillMaxWidth": true
      },
      {
        "type": "TextField",
        "id": "password_input",
        "hint": "Password (optional)",
        "singleLine": true,
        "fillMaxWidth": true,
        "password": true
      },
      {
        "type": "Button",
        "text": "Connect / Refresh",
        "action": "refreshTorrents",
        "fillMaxWidth": true
      },
      {
        "type": "Text",
        "id": "status_text",
        "text": "Status: Not connected"
      },
      {
        "type": "Spinner",
        "id": "loading_spinner",
        "visibilityId": "spinner_visible"
      },
      {
        "type": "Column",
        "weight": 1,
        "isScrollable": true,
        "dynamicChildrenId": "torrentList",
        "fillMaxWidth": true
      }
    ]
  }
}
