{
  "layout": {
    "type": "Column",
    "classes": [
      "screen"
    ],
    "fillMaxSize": true,
    "children": [
      {
        "type": "Row",
        "fillMaxWidth": true,
        "children": [
          {
            "type": "Button",
            "text": "Back",
            "classes": [
              "menu_button"
            ],
            "action": "launch:menu"
          },
          {
            "type": "Text",
            "text": "Miami Metromover",
            "classes": [
              "section_title"
            ],
            "weight": 1
          },
          {
            "type": "Button",
            "text": "Refresh",
            "icon": "data:image/svg+xml;base64,",
            "action": "refreshOverview",
            "classes": [
              "icon_only",
              "ghost_button"
            ]
          },
          {
            "type": "Button",
            "text": "Settings",
            "icon": "data:image/svg+xml;base64,",
            "action": "openSettings",
            "classes": [
              "icon_only",
              "ghost_button"
            ]
          }
        ]
      },
      {
        "type": "Row",
        "fillMaxWidth": true,
        "children": [
          {
            "type": "Button",
            "text": "Nearest Station",
            "action": "findNearestStation",
            "fillMaxWidth": true
          }
        ]
      },
      {
        "type": "Text",
        "id": "metromover_status",
        "text": "Loading Metromover data..."
      },
      {
        "type": "Spinner",
        "id": "metromover_spinner",
        "visibilityId": "metromover_spinner_visible"
      },
      {
        "type": "Column",
        "dynamicChildrenId": "metromoverContent",
        "fillMaxWidth": true,
        "weight": 1,
        "isScrollable": true
      }
    ]
  }
}