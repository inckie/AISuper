{
  "layout": {
    "type": "Column",
    "fillMaxSize": true,
    "children": [
      {
        "type": "Row",
        "fillMaxWidth": true,
        "children": [
          { "type": "Button", "text": "<< Back", "action": "launch:menu" },
          { "type": "Text", "text": "Transmission Settings", "classes": ["section_title"], "weight": 1 }
        ]
      },
      {
        "type": "TextField",
        "id": "host_input",
        "hint": "http://192.168.1.100:9091",
        "singleLine": true,
        "fillMaxWidth": true
      },
      {
        "type": "TextField",
        "id": "login_input",
        "hint": "Username (optional)",
        "singleLine": true,
        "fillMaxWidth": true
      },
      {
        "type": "TextField",
        "id": "password_input",
        "hint": "Password (optional)",
        "singleLine": true,
        "fillMaxWidth": true,
        "password": true
      },
      {
        "type": "Button",
        "text": "Connect",
        "action": "connectAndGoToList",
        "fillMaxWidth": true
      },
      {
        "type": "Text",
        "id": "status_text",
        "text": ""
      }
    ]
  }
}
