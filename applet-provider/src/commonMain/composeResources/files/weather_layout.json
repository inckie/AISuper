{
  "layout": {
    "type": "Column",
    "fillMaxSize": true,
    "children": [
      {
        "type": "Row",
        "fillMaxWidth": true,
        "children": [
          { "type": "Button", "text": "Back", "action": "launch:menu" },
          { "type": "Text", "text": "Weather", "weight": 1 }
        ]
      },
      {
        "type": "Row",
        "fillMaxWidth": true,
        "children": [
          { "type": "Button", "text": "My Location", "action": "loadWeatherCurrent" },
          { "type": "Button", "text": "Refresh", "action": "refreshCurrent" }
        ]
      },
      { "type": "Text", "id": "weather_status", "text": "Pick a location to fetch weather" },
      { "type": "Column", "dynamicChildrenId": "locationButtons", "fillMaxWidth": true },
      {
        "type": "Column",
        "dynamicChildrenId": "weatherResult",
        "fillMaxWidth": true,
        "weight": 1,
        "isScrollable": true
      }
    ]
  }
}

