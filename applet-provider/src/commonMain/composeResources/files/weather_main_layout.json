{
  "layout": {
    "type": "Column",
    "classes": ["screen"],
    "fillMaxSize": true,
    "isScrollable": true,
    "children": [
      {
        "type": "Row",
        "fillMaxWidth": true,
        "children": [
          { "type": "Button", "text": "Back", "action": "launch:menu" },
          {
            "type": "Text",
            "text": "Weather",
            "classes": ["section_title", "text-center"],
            "weight": 1
          },
          {
            "type": "Button",
            "text": "Refresh",
            "icon": "data:image/svg+xml;base64,",
            "action": "updateDashboard",
            "classes": ["icon_only", "ghost_button"]
          },
          {
            "type": "Button",
            "text": "Settings",
            "icon": "data:image/svg+xml;base64,",
            "action": "openSettings",
            "classes": ["icon_only", "ghost_button"]
          }
        ]
      },

      {
        "type": "Text",
        "id": "location_name",
        "text": "Loading...",
        "classes": ["header_text"]
      },
      {
        "type": "Row",
        "fillMaxWidth": true,
        "children": [
          {
            "type": "Column",
            "weight": 1,
            "children": [
              {
                "type": "Text",
                "id": "current_temp",
                "text": "--"
              },
              {
                "type": "Text",
                "id": "current_condition",
                "text": "--"
              },
              {
                "type": "Text",
                "id": "current_rain",
                "text": "--",
                "classes": ["small_text"]
              }
            ]
          },
          {
            "type": "Column",
            "weight": 1,
            "classes": ["align-end"],
            "children": [
              { "type": "Text", "id": "current_sunrise", "text": "--", "classes": ["small_text"] },
              { "type": "Text", "id": "current_sunset", "text": "--", "classes": ["small_text"] }
            ]
          }
        ]
      },
      {
        "type": "Text",
        "text": "Hourly Forecast",
        "classes": ["section_title"]
      },
      {
        "type": "Row",
        "isScrollable": true,
        "fillMaxWidth": true,
        "children": [
          {
            "type": "Column",
            "children": [
              { "type": "Text", "id": "h0_time", "text": "--", "classes": ["text-center"] },
              { "type": "Text", "id": "h0_emoji", "text": "--", "classes": ["text-center"] },
              { "type": "Text", "id": "h0_temp", "text": "--", "classes": ["text-center"] },
              { "type": "Text", "id": "h0_rain", "text": "--", "classes": ["small_text", "text-center"] }
            ]
          },
          {
            "type": "Column",
