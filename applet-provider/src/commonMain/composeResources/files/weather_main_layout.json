      {
        "type": "Text",
        "text": "5-Day Forecast",
        "classes": ["section_title"]
      },
      {
        "type": "Column",
        "fillMaxWidth": true,
        "children": [
          {
            "type": "Row",
            "fillMaxWidth": true,
            "children": [
              { "type": "Text", "id": "d0_day", "text": "--", "weight": 5 },
